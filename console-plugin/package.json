{
  "name": "coraza-console-plugin",
  "version": "0.0.1",
  "description": "OpenShift Console plugin for managing Coraza WAF resources",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/networking-incubator/coraza-kubernetes-operator.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn webpack",
    "build-dev": "yarn clean && yarn webpack",
    "start": "yarn webpack serve --progress",
    "start-console": "./start-console.sh",
    "lint": "yarn eslint src --fix && stylelint 'src/**/*.css' --allow-empty-input --fix",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@openshift-console/dynamic-plugin-sdk": "4.21-latest",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.21-latest",
    "@patternfly/react-core": "^6.2.2",
    "@patternfly/react-icons": "^6.2.2",
    "@patternfly/react-table": "^6.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^17.0.37",
    "@types/react-router-dom": "^5.3.3",
    "babel-loader": "^10.1.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.7.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-router": "5.3.x",
    "react-router-dom": "5.3.x",
    "style-loader": "^4.0.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "consolePlugin": {
    "name": "coraza-console-plugin",
    "version": "0.0.1",
    "displayName": "Coraza WAF Console",
    "description": "Manage Coraza WAF Engines and RuleSets from the OpenShift Console.",
    "exposedModules": {
      "OverviewPage": "./pages/OverviewPage",
      "EngineListPage": "./pages/EngineListPage",
      "EngineDetailPage": "./pages/EngineDetailPage",
      "RuleSetListPage": "./pages/RuleSetListPage",
      "RuleSetDetailPage": "./pages/RuleSetDetailPage"
    },
    "dependencies": {
      "@console/pluginAPI": "^4.21.0"
    }
  }
}
